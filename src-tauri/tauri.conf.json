{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Rise",
  "version": "0.1.0",
  "identifier": "com.rise.desktop",
  "build": {
    "frontendDist": "frontend-dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "node scripts/tauri-before-dev.mjs",
    "beforeBuildCommand": "node scripts/tauri-prepare-build.mjs"
  },
  "app": {
    "windows": [
      {
        "create": false,
        "url": "http://127.0.0.1:3000",
        "title": "Rise",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/next": "next"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
